############################
# Jupyter / Python
############################

# Notebook checkpoints
.ipynb_checkpoints/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

############################
# OS / Editor junk
############################

.DS_Store
Thumbs.db
desktop.ini
.vscode/

############################
# Temporary / Downloads
############################

*.crdownload
*.tmp
*.temp
*.log

############################
# Archives / packaged junk
############################

*.zip
*.tar
*.gz
*.rar
*.7z

############################
# Media (usually generated)
############################

*.mp4
*.avi
*.mov
*.gif

############################
# Images (often generated figures)
# Uncomment if you DON'T want figures tracked
############################
*.png
*.jpg
*.jpeg

############################
# Documents
############################

*.docx
*.pptx
# PDFs never committed — link to DOIs instead
*.pdf

############################
# Local experiment folders (IGNORE THESE)
############################

local_scratch/
research_runs/
results/
demo_spectra/
tdgsa_frames/
tdgsa_project_frames/

############################
# Large datasets / exports
############################

*.csv
*.npy
*.npz
*.h5
*.mat
# Track curated sample data (synthetic, <1 MB each)
!sample_data/*.mat

############################
# AI / notebook artifacts
############################

*_summary.json

############################
# Firmware build artifacts
############################

firmware/*.elf
firmware/*.o
firmware/*.map

############################
# Notebooks
############################

# Track canonical notebooks only
!phase_retrieval.ipynb
!notebooks/seals_simulation.ipynb

# Archive folder is ignored (history only, not tracked)
archive/
.venv/
references/pptx_figures/

############################
# Runtime data (never commit)
############################

# Flask upload store — user files, SQLite audit DB
optical_dashboard/uploads/

# Reference database (regenerated)
references/refs.db
email_to_callen.txt

############################
# Executed notebooks (output-only, not canonical)
############################

*_executed.ipynb

############################
# Overnight run outputs
############################

_overnight_results.jsonl
data/

############################
# Local REPL scratch (not for commit)
############################

repl/_repl_lut_sincos.py
repl/_repl_lut_sincos.ipynb

